# Runtime mode: demo uses bundled evidence; live uses configured providers.
RESEARCH_MODE=demo
RESEARCH_DATA_DIR=./.research_data
RESEARCH_DESK_UI_PORT=8501
RESEARCH_DESK_API_PORT=8000

# Optional live providers. Leave blank for the deterministic demo.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
TAVILY_API_KEY=

# Bounded network and ingestion limits.
REQUEST_TIMEOUT_SECONDS=30
MAX_SEARCH_RESULTS=8
MAX_PDF_BYTES=15000000
MAX_PDF_UPLOADS=5
MAX_UPLOAD_BYTES_TOTAL=30000000
MAX_PDF_PAGES=100
MAX_PDF_CHARACTERS=500000
